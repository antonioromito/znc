# Copy to deploy/podman/deploy.secrets.local (gitignored).
#
#   cp deploy/podman/deploy.secrets.local.example deploy/podman/deploy.secrets.local
#   chmod 600 deploy/podman/deploy.secrets.local

# --- Remote deploy (SSH) ---
export DEPLOY_SSH_PASSWORD='change-me'
export DEPLOY_SERVER='your-host.example.com'
export DEPLOY_SSH_USER='root'
export ZNC_PODMAN_ROOT='/opt/znc'
export DEPLOY_PODMAN_USER='centos'
export DEPLOY_BRANCH='master'
export DEPLOY_REPO_URL='https://github.com/antonioromito/znc.git'
export ZNC_PORT='8443'

# --- auto-makeconf.sh only (optional; use ./deploy/podman/run.sh --makeconf for interactive) ---
export ZNC_ADMIN_USER='your-bouncer-user'
export ZNC_ADMIN_PASS='change-me'
export ZNC_NICK='YourNick'
export ZNC_REALNAME=''
export ZNC_IRC_NETWORK='mynetwork'
export ZNC_IRC_SERVER='irc.example.net'
export ZNC_IRC_SSL='no'
export ZNC_IRC_PORT='6667'
export ZNC_IRC_CHANNELS=''
export ZNC_LISTEN_IPV6='no'
